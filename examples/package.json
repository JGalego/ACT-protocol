{
  "name": "@act/examples",
  "version": "1.0.0-rc.1",
  "description": "Seeded example applications demonstrating full ACT protocol workflows end-to-end, per PROMPT.md's Example Applications section.",
  "license": "Apache-2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "clean": "rm -rf coverage"
  },
  "dependencies": {
    "@act/api": "workspace:*",
    "@act/core": "workspace:*",
    "@act/crypto": "workspace:*",
    "@act/ledger": "workspace:*",
    "@act/policy": "workspace:*",
    "@act/sdk": "workspace:*",
    "@act/verification": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@vitest/coverage-v8": "^3.2.6",
    "fastify": "^5.2.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^3.2.6"
  }
}
