{
  "name": "@act/api",
  "version": "1.0.0-rc.1",
  "description": "ACT reference HTTP service implementing a first slice of the /v1 API contract.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/server.js",
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -b",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@act/core": "workspace:*",
    "@act/crypto": "workspace:*",
    "@act/ledger": "workspace:*",
    "@act/policy": "workspace:*",
    "@act/verification": "workspace:*",
    "@fastify/cors": "^10.0.1",
    "@fastify/rate-limit": "^10.2.1",
    "@fastify/sensible": "^6.0.2",
    "fastify": "^5.2.0",
    "fastify-plugin": "^5.0.1"
  },
  "devDependencies": {
    "@act/sdk": "workspace:*",
    "@types/node": "^22.10.2",
    "@vitest/coverage-v8": "^3.2.6",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^3.2.6"
  }
}
