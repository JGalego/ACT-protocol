{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.act-protocol.org/1.0/approval/approval-request.schema.json",
  "title": "ApprovalRequest",
  "description": "A request for approval of an exact subject version. See ACT-1.0.md section 8.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "request_id",
    "subject",
    "requested_by",
    "policy_id",
    "policy_version",
    "requested_at",
    "status",
    "signatures"
  ],
  "properties": {
    "request_id": { "$ref": "https://schemas.act-protocol.org/1.0/common/uuid.schema.json" },
    "subject": {
      "type": "object",
      "additionalProperties": false,
      "required": ["artifact_id", "version_id"],
      "properties": {
        "artifact_id": { "$ref": "https://schemas.act-protocol.org/1.0/common/uuid.schema.json" },
        "version_id": { "$ref": "https://schemas.act-protocol.org/1.0/common/digest.schema.json" }
      }
    },
    "requested_by": { "$ref": "https://schemas.act-protocol.org/1.0/common/actor-ref.schema.json" },
    "policy_id": { "$ref": "https://schemas.act-protocol.org/1.0/common/uuid.schema.json" },
    "policy_version": { "$ref": "https://schemas.act-protocol.org/1.0/common/digest.schema.json" },
    "requested_at": { "type": "string", "format": "date-time" },
    "status": {
      "type": "string",
      "enum": ["requested", "approved", "rejected", "changes_requested", "cancelled"]
    },
    "signatures": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["key_id", "algorithm", "signature"],
        "properties": {
          "key_id": { "type": "string" },
          "algorithm": { "type": "string", "enum": ["ed25519"] },
          "signature": { "type": "string" }
        }
      }
    }
  }
}
