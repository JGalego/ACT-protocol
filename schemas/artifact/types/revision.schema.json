{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.act-protocol.org/1.0/artifact/types/revision.schema.json",
  "title": "Revision",
  "description": "Marks an artifact version as a revision of a prior version, independent of the generic lineage edge.",
  "allOf": [
    {
      "$ref": "https://schemas.act-protocol.org/1.0/artifact/artifact-envelope.schema.json"
    },
    {
      "type": "object",
      "required": ["artifact_type", "data"],
      "properties": {
        "artifact_type": {
          "const": "Revision"
        },
        "data": {
          "type": "object",
          "additionalProperties": false,
          "required": ["revises_version_id", "revision_reason", "revision_kind"],
          "properties": {
            "revises_version_id": {
              "$ref": "https://schemas.act-protocol.org/1.0/common/digest.schema.json"
            },
            "revision_reason": {
              "type": "string",
              "minLength": 1
            },
            "revision_kind": {
              "type": "string",
              "enum": ["clarification", "correction", "supersession", "merge"]
            }
          }
        }
      }
    }
  ]
}
