{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.act-protocol.org/1.0/artifact/types/assumption.schema.json",
  "title": "Assumption",
  "description": "A stated belief taken as true without full verification.",
  "allOf": [
    {
      "$ref": "https://schemas.act-protocol.org/1.0/artifact/artifact-envelope.schema.json"
    },
    {
      "type": "object",
      "required": ["artifact_type", "data"],
      "properties": {
        "artifact_type": {
          "const": "Assumption"
        },
        "data": {
          "type": "object",
          "additionalProperties": false,
          "required": ["statement", "validated"],
          "properties": {
            "statement": {
              "type": "string",
              "minLength": 1
            },
            "confidence_basis": {
              "type": "string"
            },
            "validated": {
              "type": "boolean"
            }
          }
        }
      }
    }
  ]
}
