{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.act-protocol.org/1.0/artifact/types/evidence.schema.json",
  "title": "Evidence",
  "description": "Immutable or content-addressed support for a claim (ACT-1.0.md section 11.1).",
  "allOf": [
    {
      "$ref": "https://schemas.act-protocol.org/1.0/artifact/artifact-envelope.schema.json"
    },
    {
      "type": "object",
      "required": ["artifact_type", "data"],
      "properties": {
        "artifact_type": {
          "const": "Evidence"
        },
        "data": {
          "type": "object",
          "additionalProperties": false,
          "required": ["origin", "collection_method", "custody", "limitations"],
          "properties": {
            "origin": {
              "type": "string",
              "minLength": 1
            },
            "collection_method": {
              "type": "string",
              "minLength": 1
            },
            "custody": {
              "type": "array",
              "items": {
                "$ref": "https://schemas.act-protocol.org/1.0/common/actor-ref.schema.json"
              },
              "minItems": 1
            },
            "limitations": {
              "type": "string"
            }
          }
        }
      }
    }
  ]
}
