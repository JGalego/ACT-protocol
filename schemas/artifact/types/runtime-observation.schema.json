{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.act-protocol.org/1.0/artifact/types/runtime-observation.schema.json",
  "title": "RuntimeObservation",
  "description": "An observed runtime measurement.",
  "allOf": [
    {
      "$ref": "https://schemas.act-protocol.org/1.0/artifact/artifact-envelope.schema.json"
    },
    {
      "type": "object",
      "required": ["artifact_type", "data"],
      "properties": {
        "artifact_type": {
          "const": "RuntimeObservation"
        },
        "data": {
          "type": "object",
          "additionalProperties": false,
          "required": ["observed_at", "metric_name", "value", "environment"],
          "properties": {
            "observed_at": {
              "type": "string",
              "format": "date-time"
            },
            "metric_name": {
              "type": "string",
              "minLength": 1
            },
            "value": {
              "type": "number"
            },
            "environment": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    }
  ]
}
