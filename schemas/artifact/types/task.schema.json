{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.act-protocol.org/1.0/artifact/types/task.schema.json",
  "title": "Task",
  "description": "A unit of planned or completed work.",
  "allOf": [
    {
      "$ref": "https://schemas.act-protocol.org/1.0/artifact/artifact-envelope.schema.json"
    },
    {
      "type": "object",
      "required": ["artifact_type", "data"],
      "properties": {
        "artifact_type": {
          "const": "Task"
        },
        "data": {
          "type": "object",
          "additionalProperties": false,
          "required": ["title", "description", "status"],
          "properties": {
            "title": {
              "type": "string",
              "minLength": 1
            },
            "description": {
              "type": "string",
              "minLength": 1
            },
            "status": {
              "type": "string",
              "enum": ["open", "in_progress", "done", "blocked"]
            },
            "assignee": {
              "$ref": "https://schemas.act-protocol.org/1.0/common/actor-ref.schema.json"
            }
          }
        }
      }
    }
  ]
}
