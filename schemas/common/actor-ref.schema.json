{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.act-protocol.org/1.0/common/actor-ref.schema.json",
  "title": "ActorRef",
  "description": "A reference to the actor and signing key responsible for an event or attestation.",
  "type": "object",
  "additionalProperties": false,
  "required": ["actor_id", "key_id"],
  "properties": {
    "actor_id": { "$ref": "https://schemas.act-protocol.org/1.0/common/uuid.schema.json" },
    "key_id": {
      "type": "string",
      "pattern": "^[a-z0-9-]+:[0-9a-f]{16,}$",
      "description": "algorithm:fingerprint, e.g. ed25519:9f86d0..."
    },
    "display_name": { "type": "string", "maxLength": 256 }
  }
}
