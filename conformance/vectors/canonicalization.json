{
  "structural": [
    {
      "id": "key-sort-simple",
      "input": {
        "b": 1,
        "a": 2
      },
      "expectedCanonical": "{\"a\":2,\"b\":1}"
    },
    {
      "id": "key-sort-nested",
      "input": {
        "z": 1,
        "y": {
          "b": 2,
          "a": 3
        },
        "x": [3, 2, 1]
      },
      "expectedCanonical": "{\"x\":[3,2,1],\"y\":{\"a\":3,\"b\":2},\"z\":1}"
    },
    {
      "id": "array-order-preserved",
      "input": [3, 1, 2],
      "expectedCanonical": "[3,1,2]"
    },
    {
      "id": "nested-structures",
      "input": {
        "arr": [
          {
            "b": 1,
            "a": 1
          },
          {
            "d": 2,
            "c": 2
          }
        ],
        "nested": {
          "deep": {
            "z": 1,
            "a": 1
          }
        }
      },
      "expectedCanonical": "{\"arr\":[{\"a\":1,\"b\":1},{\"c\":2,\"d\":2}],\"nested\":{\"deep\":{\"a\":1,\"z\":1}}}"
    },
    {
      "id": "unicode-jcs-vector",
      "input": {
        "txt": "€$\nA'B\"\\\\\""
      },
      "expectedCanonical": "{\"txt\":\"€$\\nA'B\\\"\\\\\\\\\\\"\"}"
    },
    {
      "id": "undefined-object-value-dropped",
      "input": {
        "a": 1
      },
      "expectedCanonical": "{\"a\":1}"
    },
    {
      "id": "booleans-and-null",
      "input": {
        "t": true,
        "f": false,
        "n": null
      },
      "expectedCanonical": "{\"f\":false,\"n\":null,\"t\":true}"
    },
    {
      "id": "empty-object",
      "input": {},
      "expectedCanonical": "{}"
    },
    {
      "id": "empty-array",
      "input": [],
      "expectedCanonical": "[]"
    },
    {
      "id": "supplementary-plane-key-sort",
      "input": {
        "😀": 1,
        "a": 2
      },
      "expectedCanonical": "{\"a\":2,\"😀\":1}"
    }
  ],
  "numbers": [
    {
      "id": "zero",
      "input": 0,
      "expectedCanonical": "{\"n\":0}"
    },
    {
      "id": "negative-zero",
      "input": 0,
      "expectedCanonical": "{\"n\":0}"
    },
    {
      "id": "one",
      "input": 1,
      "expectedCanonical": "{\"n\":1}"
    },
    {
      "id": "negative-one",
      "input": -1,
      "expectedCanonical": "{\"n\":-1}"
    },
    {
      "id": "point-one",
      "input": 0.1,
      "expectedCanonical": "{\"n\":0.1}"
    },
    {
      "id": "float-rounding",
      "input": 0.30000000000000004,
      "expectedCanonical": "{\"n\":0.30000000000000004}"
    },
    {
      "id": "hundred",
      "input": 100,
      "expectedCanonical": "{\"n\":100}"
    },
    {
      "id": "hundred-point-zero",
      "input": 100,
      "expectedCanonical": "{\"n\":100}"
    },
    {
      "id": "exp-large",
      "input": 1e21,
      "expectedCanonical": "{\"n\":1e+21}"
    },
    {
      "id": "exp-small",
      "input": 0.000001,
      "expectedCanonical": "{\"n\":0.000001}"
    },
    {
      "id": "exp-smaller",
      "input": 1e-7,
      "expectedCanonical": "{\"n\":1e-7}"
    },
    {
      "id": "large-integer",
      "input": 123456789012345680,
      "expectedCanonical": "{\"n\":123456789012345680}"
    },
    {
      "id": "max-safe-integer",
      "input": 9007199254740991,
      "expectedCanonical": "{\"n\":9007199254740991}"
    },
    {
      "id": "above-max-safe-integer",
      "input": 9007199254740992,
      "expectedCanonical": "{\"n\":9007199254740992}"
    },
    {
      "id": "negative-above-max-safe-integer",
      "input": -9007199254740992,
      "expectedCanonical": "{\"n\":-9007199254740992}"
    },
    {
      "id": "smallest-denormal",
      "input": 5e-324,
      "expectedCanonical": "{\"n\":5e-324}"
    },
    {
      "id": "max-double",
      "input": 1.7976931348623157e308,
      "expectedCanonical": "{\"n\":1.7976931348623157e+308}"
    },
    {
      "id": "two-point-five",
      "input": 2.5,
      "expectedCanonical": "{\"n\":2.5}"
    },
    {
      "id": "trailing-digits",
      "input": 1000000000000000100,
      "expectedCanonical": "{\"n\":1000000000000000100}"
    }
  ]
}
