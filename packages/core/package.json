{
  "name": "@act/core",
  "version": "1.0.0-rc.1",
  "description": "ACT protocol core: canonicalization, identifiers, digests, and Ajv-based schema validation.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "presync": "node ../../scripts/sync-schemas.mjs",
    "prebuild": "pnpm run presync",
    "pretest": "pnpm run presync",
    "pretest:coverage": "pnpm run presync",
    "build": "tsc -b",
    "typecheck": "tsc -b",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "clean": "rm -rf dist *.tsbuildinfo schemas"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "uuid": "^11.0.3"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^3.2.6",
    "typescript": "^5.7.2",
    "vitest": "^3.2.6"
  }
}
